{
    "name": "descom/descommarket-feeds",
    "description": "DescomMarket Feeds",
    "license": "MIT",
    "authors": [
        {
            "name": "Descom Support",
            "email": "soporte@descom.es",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "descom/descommarket_common": "^1.7",
        "descom/pipeline": "^2.4",
        "google/apiclient": "^2.12.1",
        "illuminate/console": "*",
        "illuminate/database": "*",
        "laravel/framework": "^12.0|^13.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "guzzlehttp/guzzle": "^7.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0|^11.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "DescomMarket\\Feeds\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DescomMarket\\Feeds\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "./vendor/bin/phpunit --stop-on-error --stop-on-failure"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "DescomMarket\\Feeds\\DescomMarketFeedsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
